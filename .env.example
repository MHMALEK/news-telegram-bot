# From @BotFather on Telegram
TELEGRAM_BOT_TOKEN=

# Your user ID (integer). Message @userinfobot or log the first /start update.
TELEGRAM_CHAT_ID=

# Comma-separated RSS URLs — default mix: games, PC games, film/TV industry, tech & media
# Add or remove feeds; avoid hammering dozens of sources at a short interval.
RSS_FEED_URLS=https://www.polygon.com/rss/index.xml,https://www.pcgamer.com/rss/,https://variety.com/feed/,https://www.theverge.com/rss/index.xml

# Seconds between checks (300 = 5 minutes is a good default for RSS politeness)
POLL_INTERVAL_SECONDS=300

# On first run (empty seen history for a user): send this many newest headlines, then mark all current items as seen. 0 = no messages on cold start.
RSS_BOOTSTRAP_COUNT=1

# Max characters for the brief text from description/summary
BRIEF_MAX_LENGTH=400

# SQLite database (users, subscriptions, seen entry ids)
DATABASE_PATH=news_bot.db

# Legacy: if present and the DB has no seen rows for TELEGRAM_CHAT_ID, ids are imported once
STATE_PATH=state.json

# Skip notifying for items older than this (based on RSS published date). Mark them seen silently.
# Set to 0 or off to disable (not recommended — can spam backlog).
RSS_NOTIFY_MAX_AGE_HOURS=72

# If true, TELEGRAM_CHAT_ID's feed list is replaced with RSS_FEED_URLS on every startup (removes stale URLs).
# Do not use if you rely on /addfeed for extra feeds — they would be dropped on restart.
RSS_SYNC_PRIMARY_FEEDS_FROM_ENV=false
